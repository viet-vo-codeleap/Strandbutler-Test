# load-tests/k6/b2c/.env.example
#
# Sample env vars for the B2C k6 test suite.
# Pass these to k6 with --env flags:
#   k6 run --env BASE_URL=http://localhost:3000 --env TARGET_RATE=50 case1-average-load.js
#
# Or export them and use the RATE_ARG pattern from the README.

# ── Target ────────────────────────────────────────────────────────────────────

# Base URL for all B2C API requests. Defaults to test env if omitted.
B2C_BASE_URL=https://api.skj-test.click

# Also used by health-check scripts (case1/2 don't use this directly, but
# config.js exports it for smoke/stress tests on /health).
BASE_URL=https://api.skj-test.click

# ── Fixture dates ─────────────────────────────────────────────────────────────
# Computed dynamically by default (today + 90/93 days).
# Override only when targeting a specific dataset.

# START_DATE=2026-08-01
# END_DATE=2026-08-04
# SINGLE_DATE=2026-08-01

# ── Rate overrides ────────────────────────────────────────────────────────────
# All rates are in iter/min (requests per minute).
# Scripts convert to iter/sec internally where needed.

# case1-average-load.js  — steady-state hold rate  (default: 28 iter/min)
# TARGET_RATE=28

# case2-peak-hour.js     — peak-hour hold rate      (default: 83 iter/min)
# TARGET_RATE=83

# case3-spike.js         — burst rate at spike peak (default: 1000 iter/min)
# BURST_RATE=1000

# case4-sustained-load.js — sustained high rate     (default: 1000 iter/min)
# SUSTAIN_RATE=1000

# stress-test.js         — near-limit peak rate     (default: 1800 iter/min)
# Also pass PEAK_RATE to the analyzer so stage labels match:
#   PEAK_RATE=1800 node analyze-stress-output.js results/stress-....ndjson
# PEAK_RATE=1800
